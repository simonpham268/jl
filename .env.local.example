# Local dev secrets — COPY this file to .env.local and fill in real values.
# .env.local is gitignored — never commit credentials.
#
# CI gets these via GitHub Secrets (see .github/workflows/playwright.yml).
# dotenv automatically merges .env.local on top of .env.{env} when Playwright loads.

# ─── AIT (Restful Booker Platform Demo) ────────────────────────────────────
# Public demo defaults: admin / password (override only if testing a private fork)
AIT_ADMIN_USERNAME=admin
AIT_ADMIN_PASSWORD=password

# ─── Petstore ──────────────────────────────────────────────────────────────
PETSTORE_USERNAME=
PETSTORE_PASSWORD=
