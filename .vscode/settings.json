{
    "chat.tools.terminal.autoApprove": {
        "/^node -e \"const \\{ PDFParse \\} = require\\('pdf-parse'\\); const p = new PDFParse\\(\\); console\\.log\\('Methods:', Object\\.getOwnPropertyNames\\(Object\\.getPrototypeOf\\(p\\)\\)\\.slice\\(0, 10\\)\\);\"$/": {
            "approve": true,
            "matchCommandLine": true
        }
    },
    "gitlens.currentLine.enabled": true,
    "gitlens.currentLine.format": "${author}, ${agoOrDate}",
    "gitlens.hovers.currentLine.over": "line",
    "gitlens.blame.highlight.enabled": true,
    "gitlens.codeLens.enabled": true,
    "gitlens.codeLens.recentChange.enabled": true,
    "gitlens.codeLens.recentChange.command": "gitlens.showQuickCommitDetails",
    "gitlens.codeLens.authors.enabled": true,
    "gitlens.codeLens.authors.command": "gitlens.showQuickCommitDetails",
    "gitlens.codeLens.scopes": ["document", "containers", "blocks"]
}