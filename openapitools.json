{
  "$schema": "./node_modules/@openapitools/openapi-generator-cli/config.schema.json",
  "spaces": 2,
  "generator-cli": {
    "version": "7.17.0",
    "generators": {
      "joblogic": {
        "generatorName": "typescript-fetch",
        "output": "src/api/joblogic",
        "inputSpec": "joblogic-spec.json",
        "skipValidateSpec": true,
        "additionalProperties": {
          "apiPackage": "apis",
          "modelPackage": "models",
          "supportsES6": true,
          "useSingleRequestParameter": true,
          "withInterfaces": true,
          "platform": "browser",
          "snapshot": true,
          "skipIndexFile": false,
          "skipApiIndexFile": false,
          "skipModelIndexFile": false,
          "withNpmVersion": false,
          "withNodeVersion": false,
          "removeOperationIdPrefix": true,
          "strictSpec": false,
          "allowUnicodeIdentifiers": false,
          "prependFormOrBodyParameters": false
        }
      }
    }
  }
}
