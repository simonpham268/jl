{
  "name": "jira-azure-integration",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "npx playwright test --project=chromium",
    "test:uat": "cross-env ENVIRONMENT=uat npx playwright test --project=chromium",
    "test:staging": "cross-env ENVIRONMENT=staging npx playwright test --project=chromium",
    "test:live": "cross-env ENVIRONMENT=live npx playwright test --project=chromium",
    "test:prelive": "cross-env ENVIRONMENT=prelive npx playwright test --project=chromium",
    "test:firefox": "npx playwright test --project=firefox",
    "allure:generate": "npx allure generate allure-results --clean -o allure-report",
    "allure:open": "npx allure open allure-report",
    "allure": "npm run allure:generate && npm run allure:open",
    "install:browsers": "npx playwright install --with-deps",
    "import-suite": "npx tsx src/utils/jira/import-suite-filtered.ts",
    "crawl:tc": "npx tsx src/utils/azured-devops/get.azure.tc.ts",
    "crawl:tc:suite": "npx tsx src/utils/azured-devops/azure.ts fetch-suite",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "lint:file": "eslint --ext .ts",
    "lint:file:fix": "eslint --ext .ts --fix",
    "scan": "npx tsx src/utils/azured-devops/scan-regression-plans.ts",
    "scan:web": "npx tsx src/utils/azured-devops/scan-regression-plans.ts --web",
    "scan:mobile": "npx tsx src/utils/azured-devops/scan-regression-plans.ts --mobile",
    "scan:active": "npx tsx src/utils/azured-devops/scan-regression-plans.ts --active",
    "scan:web:active": "npx tsx src/utils/azured-devops/scan-regression-plans.ts --web --active",
    "scan:mobile:active": "npx tsx src/utils/azured-devops/scan-regression-plans.ts --mobile --active",
    "export:tc": "npx tsx src/utils/export-tc.ts",
    "crawl": "npx tsx mcp-servers/crawler.ts",
    "crawl:rn": "npx tsx mcp-servers/crawler.ts release_notes",
    "crawl:sp": "npx tsx mcp-servers/crawler.ts sharepoint",
    "crawl:notion": "npx tsx mcp-servers/crawler.ts notion",
    "crawl:notion:force": "npx tsx mcp-servers/crawler.ts notion --force",
    "export:notion": "npx tsx mcp-servers/notion-exporter.ts",
    "export:notion:force": "npx tsx mcp-servers/notion-exporter.ts --force",
    "export:notion:sp": "npx tsx mcp-servers/notion-exporter.ts --mode=sharepoint",
    "export:notion:sp:force": "npx tsx mcp-servers/notion-exporter.ts --mode=sharepoint --force",
    "crawl:tc:db": "npx tsx src/utils/azured-devops/sync-tc-db.ts",
    "crawl:tc:db:vip": "npx tsx src/utils/azured-devops/sync-tc-db.ts --plan=3198 --suite=60480",
    "test:quick": "npx playwright test --reporter=line --project=chromium"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.57.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.0.9",
    "@types/node-fetch": "^2.6.13",
    "@types/pdf-parse": "^1.1.5",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "allure-playwright": "^3.4.5",
    "cross-env": "^10.1.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-playwright": "^2.10.1",
    "googleapis": "^170.1.0",
    "pkg": "^5.8.1",
    "prettier": "3.8.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.57.2"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.8.0",
    "docx": "^9.6.1",
    "dotenv": "^17.2.3",
    "exceljs": "^4.4.0",
    "mammoth": "^1.12.0",
    "node-fetch": "^2.7.0",
    "pdf-parse": "^2.4.5",
    "tsx": "^4.0.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "pkg": {
    "assets": [
      "node_modules/**/*"
    ],
    "scripts": [
      "dist/**/*.js"
    ]
  }
}
